@comment{
  BibTeX bibliography file for no-end-for-learning.

  用法（后续你要在 note.tex 里引用时再启用）：
  - 若用 BibTeX：加入 \bibliographystyle{plain} 与 \bibliography{references}
  - 若用 biblatex：改用 \addbibresource{references.bib} 并配套 \printbibliography

  你现在可以先把条目继续往下加，格式参考下面的模板即可。
}

% ----------------------------
% 模板：期刊文章
% ----------------------------
@article{yourkey_here,
  author  = {Author, Firstname and Author, Lastname},
  title   = {Title of the paper},
  journal = {Journal Name},
  year    = {2020},
  volume  = {12},
  number  = {3},
  pages   = {1--10},
  doi     = {10.0000/xxxxxx}
}

% ----------------------------
% 模板：会议论文
% ----------------------------
@inproceedings{yourkey_inproc_here,
  author    = {Author, Firstname},
  title     = {Title of the conference paper},
  booktitle = {Proceedings of the Conference Name},
  year      = {2021},
  pages     = {100--120},
  address   = {City},
  publisher = {Publisher}
}


% ----------------------------
% 模板：预印本/论文草稿（arXiv）
% ----------------------------
@misc{yourkey_arxiv_here,
  author       = {Author, Firstname and Author, Lastname},
  title        = {Title of the preprint},
  howpublished = {\url{https://arxiv.org/abs/xxxx.xxxxx}},
  year         = {2022},
  note         = {arXiv:xxxx.xxxxx}
}

